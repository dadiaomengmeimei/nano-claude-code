{
  "name": "nano-claude-code",
  "version": "0.2.0",
  "description": "A nano-sized AI coding assistant inspired by Claude Code",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "nano-claude": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/main.js",
    "dev": "tsc --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:build": "tsc && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
